// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String?
  role         UserRole  @default(CUSTOMER)
  avatar       String?
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  refreshToken String?

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  builds        SavedBuild[]
  cartSession   CartSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  VENDOR
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  street     String
  city       String
  state      String
  country    String
  postalCode String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  brand       String
  category    ComponentCategory
  description String            @db.Text
  price       Float
  stock       Int               @default(0)
  images      String[]
  tdp         Float?
  socket      String?
  formFactor  String?
  memoryType  String?
  wattage     Float?
  isActive    Boolean           @default(true)
  isFeatured  Boolean           @default(false)

  specs          ProductSpec[]
  reviews        Review[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  compatFrom     ComponentCompat[] @relation("FromProduct")
  compatTo       ComponentCompat[] @relation("ToProduct")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([slug])
  @@index([brand])
  @@map("products")
}

enum ComponentCategory {
  CPU
  GPU
  RAM
  MOTHERBOARD
  STORAGE
  PSU
  CASE
  COOLING
  MONITOR
  KEYBOARD
  MOUSE
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  key       String
  value     String
  unit      String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specs")
}

model ComponentCompat {
  id            String          @id @default(cuid())
  fromProductId String
  toProductId   String
  status        CompatStatus    @default(COMPATIBLE)
  message       String?
  details       String?         @db.Text

  fromProduct Product @relation("FromProduct", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct   Product @relation("ToProduct", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId])
  @@map("component_compat")
}

enum CompatStatus {
  COMPATIBLE
  WARNING
  INCOMPATIBLE
}

model Review {
  id        String  @id @default(cuid())
  productId String
  userId    String
  rating    Int     // 1-5
  title     String
  body      String  @db.Text
  isVerified Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model CartSession {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?    @unique
  items     CartItem[]

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_sessions")
}

model CartItem {
  id            String  @id @default(cuid())
  cartSessionId String
  productId     String
  quantity      Int     @default(1)
  price         Float

  cartSession CartSession @relation(fields: [cartSessionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartSessionId, productId])
  @@map("cart_items")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                    String        @id @default(cuid())
  userId                String
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethod         String
  subtotal              Float
  tax                   Float
  shipping              Float         @default(0)
  total                 Float
  currency              String        @default("USD")
  shippingAddressId     String
  stripePaymentIntentId String?
  mercadopagoOrderId    String?
  notes                 String?
  trackingNumber        String?

  user            User      @relation(fields: [userId], references: [id])
  shippingAddress Address   @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAYMENT_PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Saved Builds ─────────────────────────────────────────────────────────────

model SavedBuild {
  id       String  @id @default(cuid())
  userId   String
  name     String
  data     Json    // Stores the full build configuration
  isPublic Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_builds")
}
